# Public host port. The API listens on port 8080 inside the container.
API_PORT=8081

# Remote MongoDB example:
# MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
#
# MongoDB running directly on the Docker host (Linux/macOS/Windows):
MONGO_URI=mongodb://host.docker.internal:27017
MONGO_DATABASE=fark_noi

WORKSPACE_ID=wsp_demo
JWT_SECRET=local-development-secret-change-me
DEV_COLLABORATOR_ID=col_demo
CORS_ORIGINS=http://localhost:3000
MCP_ENABLED=false
MCP_PATH=/mcp
